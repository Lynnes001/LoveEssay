[Unit]
Description=LoveEssay Proxy Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/loveessay
EnvironmentFile=/etc/loveessay/loveessay.env
ExecStart=/usr/bin/node /var/www/loveessay/server.js
Restart=always
RestartSec=3
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
